# Copy this file to .env.production and fill in real values before deploying.
# NEVER commit the resulting .env.production file (it is already gitignored).

# ---- Postgres (read by the "db" service) ----
POSTGRES_USER=sunsetbeach
POSTGRES_PASSWORD=replace-with-a-strong-random-password
POSTGRES_DB=sunsetbeach

# ---- App database connection (read by the "app" service) ----
# Host is "db" — the docker-compose service name on the internal network,
# NOT localhost. User/password/db must match the POSTGRES_* values above.
DATABASE_URL="postgresql://sunsetbeach:replace-with-a-strong-random-password@db:5432/sunsetbeach"

# ---- NextAuth ----
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-32-byte-secret"
NEXTAUTH_URL="https://prostak59.duckdns.org"

# ---- Resend (https://resend.com) — leave empty to log emails instead of sending ----
RESEND_API_KEY="replace-with-your-resend-api-key"
EMAIL_FROM="The Sunset Beach Resort & Spa <bookings@prostak59.duckdns.org>"

# ---- Seed script: initial admin account (used once by `npm run db:seed`) ----
SEED_ADMIN_EMAIL="admin@prostak59.duckdns.org"
SEED_ADMIN_PASSWORD="replace-with-a-strong-password"

NODE_ENV=production
