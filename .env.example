# Postgres (matches docker-compose.yml for local dev)
DATABASE_URL="postgresql://sunsetbeach:sunsetbeach@localhost:5434/sunsetbeach"

# NextAuth — generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-32-byte-secret"
NEXTAUTH_URL="http://localhost:3000"

# Resend (https://resend.com) — leave RESEND_API_KEY unset in dev to log emails to the console instead of sending
RESEND_API_KEY=""
EMAIL_FROM="The Sunset Beach Resort & Spa <bookings@sunsetbeach.example>"

# Seed script: initial admin account
SEED_ADMIN_EMAIL="admin@sunsetbeach.example"
SEED_ADMIN_PASSWORD="change-me-after-first-login"
